# Required: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
CHAT_ENCRYPTION_KEY=your_64_hex_char_key_here

# Optional: Port (Vercel sets PORT automatically)
PORT=3001

# Optional: Environment
NODE_ENV=production

# Optional: Enable debug logging
DEBUG=true

# Optional: Log file path (for persistent logging)
LOG_FILE=./chat-security.log

# Optional: IP hash salt (for privacy in logs)
IP_HASH_SALT=your_random_salt_here
